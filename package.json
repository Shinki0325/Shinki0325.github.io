{
  "name": "maki-archive-source",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:manager": "pnpm --filter @maki/manager dev",
    "build": "astro build",
    "build:manager": "pnpm --filter @maki/manager build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "astro check",
    "docs:check": "node -e \"import('node:fs').then(fs => fs.accessSync('docs/authoring.md'))\"",
    "check:links": "playwright test",
    "validate:public": "pnpm build"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
