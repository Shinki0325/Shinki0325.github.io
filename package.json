{
  "name": "maki-archive-source",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:manager": "pnpm --filter @maki/manager dev",
    "dev:manager:server": "pnpm --filter @maki/manager server",
    "dev:manager:local": "bash scripts/restart-manager-local.sh",
    "music:acquire": "node scripts/acquire-home-music-tracks.mjs",
    "sync:bangumi": "node scripts/sync-bangumi-collections.mjs",
    "build": "node scripts/generate-archive-thumbnails.mjs && node scripts/clean-build.mjs && astro build",
    "build:manager": "pnpm --filter @maki/manager build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "astro check && pnpm check:manager",
    "check:manager": "pnpm --filter @maki/manager build",
    "docs:check": "node -e \"import('node:fs').then(fs => fs.accessSync('docs/authoring.md'))\"",
    "check:links": "vitest run tests/wiki-links.test.ts tests/reference-graph.test.ts",
    "validate:public": "tsx scripts/assert-public-content.mjs"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@maki/content-core": "workspace:*",
    "@nanostores/react": "^1.1.0",
    "astro": "^5.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.24.0",
    "nanostores": "^1.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@playwright/test": "^1.54.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "sharp": "^0.35.3",
    "tsx": "^4.23.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
