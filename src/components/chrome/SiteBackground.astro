---
import { siteShell } from "../../config/site-shell";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
const isHome = currentPath === "/";
const homeBackground = siteShell.homeBackground ?? {
  enabled: true,
  videoSrc: "/uploads/backgrounds/home-loop-h264.mp4",
  poster: "/uploads/backgrounds/home-loop-poster.jpg",
};
const backgroundImages: readonly string[] = siteShell.backgroundImages ?? [];
const nonHomeBackgroundImages: readonly string[] = isHome ? [] : backgroundImages;
---

<div class="site-backdrop" aria-hidden="true">
  {
    isHome && homeBackground.enabled && homeBackground.videoSrc && (
      <video
        autoplay
        class="site-backdrop__video"
        data-home-background-video
        loop
        muted
        playsinline
        poster={homeBackground.poster}
        preload="none"
      >
        <source data-home-background-source data-src={homeBackground.videoSrc} type="video/mp4" />
      </video>
    )
  }
  <div class="site-backdrop__veil"></div>
  <div class="site-backdrop__gradient"></div>

  <div class="site-backdrop__glow glow-one"></div>
  <div class="site-backdrop__glow glow-two"></div>
  <div class="site-backdrop__glow glow-three"></div>

  <div class="site-backdrop__slider" data-background-slider={nonHomeBackgroundImages.length > 1 ? "true" : undefined}>
    {nonHomeBackgroundImages.map((src) => (
      <div
        class="site-backdrop__image"
        data-background-slide
        data-background-src={src}
      ></div>
    ))}
  </div>
  {
    nonHomeBackgroundImages.length > 1 && (
      <script
        is:inline
        set:html={`
          (() => {
            const BACKGROUND_PRELOAD_DELAY_MS = 55_000;
            const BACKGROUND_ROTATION_MS = 60_000;
            const BACKGROUND_STATE_KEY = "blog:nonhome-background-state:v1";
            const cleanupCallbacks = [];

            const readBackgroundState = (slideCount) => {
              try {
                const parsed = JSON.parse(window.sessionStorage.getItem(BACKGROUND_STATE_KEY));
                if (
                  !parsed ||
                  !Number.isInteger(parsed.activeIndex) ||
                  parsed.activeIndex < 0 ||
                  parsed.activeIndex >= slideCount ||
                  !Number.isFinite(parsed.nextRotationAt) ||
                  parsed.nextRotationAt <= 0
                ) {
                  return null;
                }
                return parsed;
              } catch {
                return null;
              }
            };

            const writeBackgroundState = (activeIndex, nextRotationAt) => {
              try {
                window.sessionStorage.setItem(
                  BACKGROUND_STATE_KEY,
                  JSON.stringify({ activeIndex, nextRotationAt }),
                );
              } catch {
                // The visual fallback remains functional when storage is unavailable.
              }
            };

            const setupBackgroundCarousels = () => {
              document.querySelectorAll("[data-background-slider]").forEach((slider) => {
                if (slider.dataset.carouselReady === "true") {
                  return;
                }

                const slides = Array.from(slider.querySelectorAll("[data-background-slide]"));
                if (slides.length <= 1) {
                  return;
                }

                slider.dataset.carouselReady = "true";
                const now = Date.now();
                const restored = readBackgroundState(slides.length);
                let activeIndex = restored?.activeIndex ?? Math.floor(Math.random() * slides.length);
                let nextRotationAt = restored?.nextRotationAt ?? now + BACKGROUND_ROTATION_MS;
                while (nextRotationAt <= now) {
                  activeIndex = (activeIndex + 1) % slides.length;
                  nextRotationAt += BACKGROUND_ROTATION_MS;
                }
                writeBackgroundState(activeIndex, nextRotationAt);

                let renderedIndex = -1;
                let preloadTimer;
                let rotationTimer;

                const loadSlide = (slide) => {
                  if (!slide || slide.dataset.backgroundLoaded === "true") {
                    return;
                  }

                  const src = slide.dataset.backgroundSrc;
                  if (!src) {
                    return;
                  }

                  slide.style.setProperty("--bg-url", "url('" + src + "')");
                  slide.dataset.backgroundLoaded = "true";
                };

                const scheduleNextPreload = () => {
                  clearTimeout(preloadTimer);
                  const preloadAt = nextRotationAt - (
                    BACKGROUND_ROTATION_MS - BACKGROUND_PRELOAD_DELAY_MS
                  );
                  preloadTimer = setTimeout(() => {
                    loadSlide(slides[(activeIndex + 1) % slides.length]);
                  }, Math.max(0, preloadAt - Date.now()));
                };

                const activateSlide = (nextIndex) => {
                  loadSlide(slides[nextIndex]);
                  slides[renderedIndex]?.classList.remove("is-active");
                  renderedIndex = nextIndex;
                  slides[renderedIndex]?.classList.add("is-active");
                  slider.dataset.backgroundActiveIndex = String(nextIndex);
                };

                const scheduleRotation = () => {
                  clearTimeout(rotationTimer);
                  rotationTimer = setTimeout(() => {
                    const rotationNow = Date.now();
                    do {
                      activeIndex = (activeIndex + 1) % slides.length;
                      nextRotationAt += BACKGROUND_ROTATION_MS;
                    } while (nextRotationAt <= rotationNow);
                    writeBackgroundState(activeIndex, nextRotationAt);
                    activateSlide(activeIndex);
                    scheduleNextPreload();
                    scheduleRotation();
                  }, Math.max(0, nextRotationAt - Date.now()));
                };

                activateSlide(activeIndex);
                scheduleNextPreload();
                scheduleRotation();

                cleanupCallbacks.push(() => {
                  clearTimeout(rotationTimer);
                  clearTimeout(preloadTimer);
                });
              });
            };

            setupBackgroundCarousels();
            document.addEventListener("astro:page-load", setupBackgroundCarousels);
            document.addEventListener("astro:before-swap", () => {
              cleanupCallbacks.splice(0).forEach((cleanup) => cleanup());
            });
          })();
        `}
      />
    )
  }
  {
    isHome && homeBackground.enabled && homeBackground.videoSrc && (
      <script
        is:inline
        set:html={`
          (() => {
            const canLoadMotionBackground = () => {
              const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
              const saveData = Boolean(connection?.saveData);
              const reducedMotion = window.matchMedia?.("(prefers-reduced-motion: reduce)")?.matches ?? false;
              return !saveData && !reducedMotion;
            };

            const loadHomeBackgroundVideo = () => {
              if (!canLoadMotionBackground()) {
                return;
              }

              document.querySelectorAll("[data-home-background-video]").forEach((video) => {
                if (video.dataset.videoReady === "true") {
                  return;
                }

                const source = video.querySelector("[data-home-background-source]");
                const src = source?.dataset.src;
                if (!source || !src) {
                  return;
                }

                video.dataset.videoReady = "true";
                source.setAttribute("src", src);
                video.load();
                video.play?.().catch(() => {});
              });
            };

            const scheduleHomeBackgroundVideo = () => {
              if ("requestIdleCallback" in window) {
                window.requestIdleCallback(loadHomeBackgroundVideo, { timeout: 2600 });
                return;
              }

              window.setTimeout(loadHomeBackgroundVideo, 1400);
            };

            window.addEventListener("load", scheduleHomeBackgroundVideo, { once: true });
            document.addEventListener("astro:page-load", scheduleHomeBackgroundVideo);
          })();
        `}
      />
    )
  }
</div>
