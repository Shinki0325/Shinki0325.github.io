---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import ClickEffect from "../components/chrome/ClickEffect";
import SplashScreen from "../components/home/SplashScreen";
import FloatingPlayer from "../components/music/FloatingPlayer";
import MusicRuntime from "../components/music/MusicRuntime";
import SiteBackground from "../components/chrome/SiteBackground.astro";
import { buildAppearanceStyle, siteAppearance } from "../config/site-appearance";
import TopNav from "../components/chrome/TopNav";
import { siteShell } from "../config/site-shell";
import { siteDescription, siteTitle } from "../data/site";
import { buildHomeSearchIndex } from "../lib/home-shell";
import {
  getPublishedAlbums,
  getPublishedArticles,
  getPublishedNotes,
  getPublishedReferences,
} from "../lib/public-content";

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = siteTitle,
  description = siteDescription,
  currentPath = Astro.url.pathname,
} = Astro.props;
const siteIcon = siteShell.profile?.avatarUrl ?? "https://s1.ax1x.com/2023/07/28/pCx6j3R.jpg";
const appearanceStyle = buildAppearanceStyle(siteAppearance);
const [articles, albums, notes, references] = await Promise.all([
  getPublishedArticles(),
  getPublishedAlbums(),
  getPublishedNotes(),
  getPublishedReferences(),
]);
const searchItems = buildHomeSearchIndex({ articles, albums, notes, references });
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <ClientRouter />
    <title>{title}</title>
    <meta content={description} name="description" />
    <link href="https://s1.ax1x.com" rel="preconnect" crossorigin />
    <link href="https://pic.imgdd.cc" rel="preconnect" crossorigin />
    <link href="https://api.injahow.cn" rel="preconnect" crossorigin />
    <link href="https://music.163.com" rel="preconnect" crossorigin />
    <link href={siteIcon} rel="icon" />
    <link href={siteIcon} rel="shortcut icon" />
    <link href={siteIcon} rel="apple-touch-icon" />
    <style is:inline set:html={`:root {${appearanceStyle}}`}></style>
  </head>
  <body style={appearanceStyle}>
    <SiteBackground currentPath={currentPath} />
    <TopNav
      client:load
      currentPath={currentPath}
      searchItems={searchItems}
      searchPlaceholder={siteShell.search?.placeholder ?? "搜索站内内容..."}
    />
    <div transition:persist="global-music-runtime">
      <MusicRuntime client:load />
    </div>
    <div transition:persist="global-floating-player">
      <FloatingPlayer client:load initialPathname={currentPath} />
    </div>
    <SplashScreen client:load />
    <ClickEffect client:load />

    <main class="shell">
      <div class="page-stack">
        <slot />
      </div>
    </main>
  </body>
</html>
