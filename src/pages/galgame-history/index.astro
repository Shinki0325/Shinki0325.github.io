---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { galgameHistoryPreview } from "../../data/galgame-history-preview";
import "../../styles/galgame-history.css";

const route = galgameHistoryPreview.museumRoute;
const experience = galgameHistoryPreview.museumExperience;
const cardById = new Map(experience.nodeCards.map((card) => [card.nodeId, card]));
const trackIds = { left: "works", center: "public", right: "systems" } as const;
const relationCounts = new Map<string, number>();
for (const relation of route.links) {
  relationCounts.set(relation.from, (relationCounts.get(relation.from) ?? 0) + 1);
  relationCounts.set(relation.to, (relationCounts.get(relation.to) ?? 0) + 1);
}

const presentationRecords = route.nodes.map((node) => {
  const card = cardById.get(node.id);
  return {
    nodeId: node.id,
    compactTitleZh: node.labelZh,
    displayYear: node.yearStart,
    dateDisplay: node.dateDisplay,
    dateStart: node.dateDisplay === "UNDATED" ? null : node.dateDisplay,
    track: trackIds[node.track],
    cardKind: node.type.toLowerCase(),
    sourceTier: card?.sourceTiers[0] ?? "REVIEW",
    dossierStatus: "complete",
    presentationTier: node.importance === "primary" ? "main" : "supporting",
    nodeTypeLabelEn: node.type,
    evidenceLabelEn: card?.sourceTiers[0] ?? "REVIEW",
    branchAnchorIds: node.importance === "secondary" ? (card?.relationHints.slice(0, 2).map((hint) => hint.targetNodeId) ?? []) : [],
    archiveNoteRecommendation: "preserve",
    presentationReasonZh: card?.deckZh ?? node.summaryZh,
  };
});

const previewData = {
  generatedAt: route.generatedAt,
  reviewedRelationCount: route.authority.reviewedRelationCount,
  timeRange: { start: 1979, end: 1999 },
  tracks: [
    { id: "works", label: "WORKS / FORMS", labelZh: "作品 / 形式" },
    { id: "public", label: "PUBLIC / INSTITUTIONS", labelZh: "公共 / 制度" },
    { id: "systems", label: "SYSTEMS / CIRCULATION", labelZh: "平台 / 流通" },
  ],
  nodes: route.nodes.map((node) => ({
    id: node.id,
    title: node.labelZh,
    cardTier: node.type.toLowerCase(),
    cardStatus: "standard-complete",
    completed: true,
    sourceTier: cardById.get(node.id)?.sourceTiers[0] ?? "REVIEW",
    displayYear: node.yearStart,
    dateLabel: node.dateDisplay,
    dateMode: node.dateDisplay === "UNDATED" ? "undated" : "year",
    degree: relationCounts.get(node.id) ?? 0,
    exhibitRole: node.importance === "primary" ? "story" : "branch",
    track: trackIds[node.track],
    primary: node.importance === "primary",
  })),
  relations: route.links.map((relation) => ({
    id: relation.id,
    from: relation.from,
    to: relation.to,
    relationType: relation.relationType,
    label: relation.relationLabelZh,
    publicLabelZh: relation.relationLabelZh,
    evidenceMode: "reviewed",
    causalStrength: relation.directionality === "contextual" ? "contextual" : "none",
  })),
};

const cards = experience.nodeCards.map((card) => ({
  nodeId: card.nodeId,
  titleZh: card.titleZh,
  compactTitleZh: route.nodes.find((node) => node.id === card.nodeId)?.labelZh ?? card.titleZh,
  dateDisplay: card.dateDisplay,
  archiveNoteZh: card.introZh,
  deckZh: card.deckZh,
  sections: card.sections,
  sourceTier: card.sourceTiers[0] ?? "REVIEW",
  caveats: card.caveats,
  relationHints: card.relationHints,
  imageSlot: { placeholderZh: card.imagePlaceholder },
}));

const guidedConfig = {
  worldNodeIds: route.nodes.filter((node) => node.importance === "primary").map((node) => node.id),
  guideLinks: route.links.slice(0, 32).map((relation) => [relation.from, relation.to]),
  chapters: route.galleries.map((gallery, index) => ({
    id: gallery.id,
    number: String(index + 1).padStart(2, "0"),
    label: gallery.theme,
    titleZh: gallery.titleZh,
    yearRange: [gallery.yearStart, gallery.yearEnd],
    nodeIds: route.nodes.filter((node) => node.galleryId === gallery.id).map((node) => node.id),
  })),
};

const clientPayload = JSON.stringify({ previewData, guidedConfig, presentationRecords, cards }).replace(/</g, "\\u003c");
---

<BaseLayout title="GALGAME CHRONICLE" description="1979-1999 美少女游戏编年档案。" currentPath="/galgame-history/">
  <script is:inline>document.documentElement.dataset.visualStyle = "tactical-tree";</script>
  <link rel="stylesheet" href="/galgame-history/styles.css" />
  <link rel="stylesheet" href="/galgame-history/theme-tactical-tree.css" />

  <main class="research-tree" data-chronological-tree>
    <header class="site-heading">
      <span class="site-heading__code" aria-hidden="true">CHRONICLE / 01</span>
      <div class="site-heading__identity">
        <p class="site-heading__system">GALGAME CHRONICLE</p>
        <h1>美少女游戏编年档案</h1>
      </div>
      <div class="site-heading__range">
        <span>ARCHIVE RANGE</span>
        <strong>1979-1999</strong>
      </div>
      <div class="archive-count"><strong data-completed-dossier-count>100</strong><span>FILES</span><strong data-public-dossier-count>100</strong><span>PUBLIC</span></div>
    </header>

    <div data-app></div>
    <script is:inline type="application/json" data-galgame-chronicle-payload set:html={clientPayload}></script>
  </main>

  <script type="module" src="/galgame-history/app.js"></script>
</BaseLayout>
