---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteShell } from "../config/site-shell";

const avatarUrl = siteShell.profile?.avatarUrl ?? "https://s1.ax1x.com/2023/07/28/pCx6j3R.jpg";
const displayName = siteShell.profile?.displayName ?? siteShell.brand.title;
const coverImage = "/uploads/backgrounds/home-loop-poster.jpg";
---

<BaseLayout title="About">
  <article class="about-shell" data-about-shell>
    <div class="about-cover" data-about-cover>
      <img alt="About Hero" src={coverImage} />
      <span aria-hidden="true"></span>
    </div>

    <div class="about-body">
      <div class="about-avatar" data-about-avatar>
        <img alt={`${displayName} avatar`} src={avatarUrl} />
      </div>

      <header class="about-head">
        <div>
          <h1>关于我</h1>
          <p>Hello World, I'm {displayName}</p>
        </div>

        <nav aria-label="关于页分区" class="about-tabs" data-about-tabs>
          <a class="is-active" href="#intro">自我介绍</a>
          <a href="#focus">研究动态</a>
        </nav>
      </header>

      <div class="about-divider"></div>

      <section class="about-intro prose" data-about-intro id="intro">
        <h2>关于我</h2>
        <p>
          这个新站会继续作为公开归档页使用，用来整理长文、短笔记和一些长期留下来的想法。
        </p>
        <p>
          目前这里更像一座慢慢搭起来的资料岛：一边放文稿，一边存参考资料、阅读笔记、照片墙和一些还没成形的兴趣线索。
        </p>

        <h3 id="focus">近期目标</h3>
        <ul>
          <li>把 galgame 与 90 年代媒介环境相关资料整理成可长期维护的资料库。</li>
          <li>持续补全视频稿、参考引用和站内交叉链接。</li>
          <li>保留一点轻松的个人空间，让网站不只是资料柜，也像能坐下来的房间。</li>
        </ul>
      </section>
    </div>
  </article>
</BaseLayout>
