---
import BaseLayout from "../layouts/BaseLayout.astro";
import bangumiCollections from "../data/bangumi-collections.json";
import { siteShell } from "../config/site-shell";
import { buildAboutCollectionPayload } from "../lib/about-collection";
import "../styles/about.css";

const avatarUrl = siteShell.profile?.avatarUrl ?? "https://s1.ax1x.com/2023/07/28/pCx6j3R.jpg";
const collection = buildAboutCollectionPayload(bangumiCollections);
const animeCount = collection.categories.find((category) => category.key === "anime")?.count ?? 0;
const gameCount = collection.categories.find((category) => category.key === "game")?.count ?? 0;

const modules = [
  {
    index: "01",
    href: "/?archive=birthday#character-archive",
    title: "角色生日星图",
    copy: "按日期阅读角色、作品和相邻生日关系。",
  },
  {
    index: "02",
    href: "/?archive=height#character-archive",
    title: "角色身高图鉴",
    copy: "用立绘比例查看角色视觉设定。",
  },
  {
    index: "03",
    href: "/galgame-history/",
    title: "GALGAME CHRONICLE",
    copy: "按时间和分支路线阅读历史词条。",
  },
  {
    index: "04",
    href: "/#home-music-card",
    title: "首页音乐盒",
    copy: "品鉴旮旯game主理人的音乐品位。",
  },
] as const;
---

<BaseLayout title="关于项目">
  <div class="about-project" data-about-project>
    <header class="about-project__identity" data-about-identity>
      <span class="about-project__avatar"><img alt="" src={avatarUrl} /></span>
      <div><small>ABOUT THIS PROJECT</small><h1>美少女游戏生态档案</h1></div>
      <b>SYSTEM / PROJECT OVERVIEW</b>
    </header>

    <section class="about-project__hero" data-about-hero>
      <div class="about-project__hero-copy">
        <span class="about-project__eyebrow">PROJECT OVERVIEW</span>
        <h2>并非追忆往昔的荣光，<br /><strong>而是重现诞生这些美妙故事的瞬间</strong></h2>
        <p>这里记录的不只是作品本身，也追寻它们诞生时的制作现场、玩家记忆与时代空气。希望当我们再次回望那些故事时，看到的不仅是屏幕中的角色，也能重新靠近那些创造它、等待它，并曾为它心动的人们。</p>
        <div class="about-project__tags" aria-label="项目关注范围">
          {["作品", "制作方", "玩家", "社会背景", "互动游戏"].map((tag) => <span>{tag}</span>)}
        </div>
      </div>
      <div class="about-project__guide" data-about-guide aria-hidden="true">
        <img
          alt=""
          decoding="async"
          fetchpriority="high"
          height="1773"
          src="/uploads/about/about-guide-character.webp"
          width="696"
        />
      </div>
    </section>

    <section class="about-project__band" data-about-modules>
      <header class="about-project__section-head"><h2>已经完成的入口</h2><span>ONLINE MODULES / 04</span></header>
      <div class="about-project__modules">
        {modules.map((module) => (
          <a class="about-project__module" href={module.href}>
            <small>MODULE {module.index}</small><strong>{module.title}</strong><p>{module.copy}</p><span aria-hidden="true">›</span>
          </a>
        ))}
      </div>
    </section>

    <section class="about-project__band" data-about-research>
      <header class="about-project__section-head"><h2>正在推进的内容</h2><span>RESEARCH IN PROGRESS</span></header>
      <div class="about-project__research-grid">
        <article><small>DATA<br />BUILDING</small><div><h3>作品与歌手分析</h3><p>整理 ErogameScape、VNDB、Bangumi 中的作品、歌曲、歌手、制作方与评价关系。</p></div></article>
        <article><small>GAME<br />DESIGN</small><div><h3>资料驱动问答游戏</h3><p>把已经核实的知识库内容转化成可以游玩的提问与反馈。</p></div></article>
        <article><small>TEXT<br />EDITING</small><div><h3>Chronicle 词条整理</h3><p>继续整理具体历史词条，并补充来源、时间与相互关系。</p></div></article>
        <article><small>SOURCE<br />REVIEW</small><div><h3>分析资料扩展</h3><p>保留来源、版本和不确定性，再逐步开放比较与分析视图。</p></div></article>
      </div>
    </section>

    <section class="about-project__band" data-about-route>
      <header class="about-project__section-head"><h2>项目路线</h2><span>PROJECT ROUTE</span></header>
      <div class="about-project__route">
        <article><small>01 / ARCHIVE</small><h3>资料档案</h3><p>完善资料入口、角色图鉴和历史编年结构。</p></article>
        <article><small>02 / PLAY</small><h3>问答游戏</h3><p>以核实后的知识库为基础开发网页问答。</p></article>
        <article class="is-future"><small>03 / ECOLOGY</small><h3>互动世界</h3><p>以 80-90 年代业界生态为背景制作网页互动游戏。</p></article>
      </div>
    </section>

    <section
      class="about-project__band about-project__collection"
      data-about-collection
      data-collection-endpoint="/data/about-collection.json"
    >
      <header class="about-project__collection-head">
        <div><span class="about-project__eyebrow">PERSONAL COLLECTION</span><h2>番组收藏档案</h2><p>个人观看、游玩与评分记录，放在项目主线之后。</p></div>
        <div class="about-project__counts"><span><strong>{animeCount}</strong>动画</span><span><strong>{gameCount}</strong>游戏</span></div>
      </header>
      <div class="about-project__shelf" data-about-collection-showcase>
        {collection.showcase.map((item) => (
          <a href={item.url} rel="noreferrer" target="_blank">
            <img alt={item.title} decoding="async" height="4" loading="lazy" referrerpolicy="no-referrer" src={item.cover} width="3" />
            <span>{item.title}</span>
          </a>
        ))}
      </div>
      <div class="about-project__collection-action">
        <p>默认展示六项个人收藏；完整筛选仅在展开后加载。</p>
        <button aria-controls="about-collection-panel" aria-expanded="false" data-about-collection-toggle type="button">展开完整收藏</button>
      </div>
      <div class="about-project__collection-panel" data-about-collection-panel hidden id="about-collection-panel" tabindex="-1"></div>
    </section>
  </div>
  <script>
    import "../scripts/about-collection";
  </script>
</BaseLayout>
