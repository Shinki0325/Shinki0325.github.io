---
import ArticleCard from "../../components/ArticleCard.astro";
import NoteCard from "../../components/NoteCard.astro";
import {
  getPublishedArticles,
  getPublishedNotes,
  getPublishedTags
} from "../../lib/public-content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const articles = await getPublishedArticles();
const notes = await getPublishedNotes();
const tags = await getPublishedTags();

export async function getStaticPaths() {
  return (await getPublishedTags()).map((tag) => ({
    params: { tag }
  }));
}

const { tag } = Astro.params;
const taggedArticles = articles.filter((entry) => entry.data.tags.includes(tag ?? ""));
const taggedNotes = notes.filter((entry) => entry.data.tags.includes(tag ?? ""));
---

<BaseLayout title={`标签：${tag}`} description="浏览当前标签下的公开条目。">
  <section class="feature-section glass-panel stack">
    <div class="section-head">
      <div>
        <p class="eyebrow">标签索引</p>
        <h2>标签：{tag}</h2>
      </div>
    </div>
    {tags.length > 0 && <p class="muted">这里收纳所有带有这个标签的公开条目。</p>}
    <div class="grid cards">
      {taggedArticles.map((entry) => <ArticleCard entry={entry} />)}
      {taggedNotes.map((entry) => <NoteCard entry={entry} />)}
    </div>
  </section>
</BaseLayout>
