---
import { getCollection } from "astro:content";
import TopicCard from "../../components/TopicCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const topics = await getCollection("topics");
---

<BaseLayout title="专题" description="围绕主题组织的视频稿、笔记和资料节点。">
  <section class="feature-section glass-panel stack">
    <div class="section-head">
      <div>
        <p class="eyebrow">主题索引</p>
        <h2>专题</h2>
      </div>
    </div>
    <div class="grid cards">
      {topics.map((entry) => <TopicCard entry={entry} />)}
    </div>
  </section>
</BaseLayout>
