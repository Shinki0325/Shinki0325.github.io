---
import BacklinkList from "../../components/BacklinkList.astro";
import ReferenceMeta from "../../components/ReferenceMeta.astro";
import ReferenceReading from "../../components/ReferenceReading.astro";
import PostLayout from "../../layouts/PostLayout.astro";
import { getPublishedArticles, getPublishedNotes, getPublishedReferences } from "../../lib/public-content";
import { buildReferenceIntro, buildRelatedReferenceSlugs } from "../../lib/reference-library";
import { createReferenceIndex } from "../../lib/reference-index";
import { buildReferenceReadingState } from "../../lib/reference-reading";

export async function getStaticPaths() {
  const makeEntryId = (collection: "references" | "articles" | "notes", slug: string) =>
    `${collection}:${slug}`;
  const isLinkItem = (
    item: { href: string; title: string } | undefined
  ): item is { href: string; title: string } => Boolean(item);

  const [references, articles, notes] = await Promise.all([
    getPublishedReferences(),
    getPublishedArticles(),
    getPublishedNotes()
  ]);

  const graph = createReferenceIndex(
    references.map((entry) => ({
      ...entry,
      slug: makeEntryId("references", entry.slug)
    })),
    [
      ...articles.map((entry) => ({
        ...entry,
        slug: makeEntryId("articles", entry.slug)
      })),
      ...notes.map((entry) => ({
        ...entry,
        slug: makeEntryId("notes", entry.slug)
      }))
    ]
  );
  const sourceLookup = new Map<string, { href: string; kind: string; title: string }>();
  const publicReferenceLookup = new Map(
    references.map((reference) => [
      reference.slug,
      {
        href: `/references/${reference.slug}/`,
        title: reference.data.title
      }
    ])
  );
  const publicArticleLookup = new Map(
    articles.map((article) => [
      article.slug,
      {
        href: `/articles/${article.slug}/`,
        title: article.data.title
      }
    ])
  );

  for (const reference of references) {
    sourceLookup.set(makeEntryId("references", reference.slug), {
      href: `/references/${reference.slug}/`,
      kind: reference.data.kind === "source" ? "参考资料" : "专题资料",
      title: reference.data.title
    });
  }

  for (const article of articles) {
    sourceLookup.set(makeEntryId("articles", article.slug), {
      href: `/articles/${article.slug}/`,
      kind: "文章",
      title: article.data.title
    });
  }

  for (const note of notes) {
    sourceLookup.set(makeEntryId("notes", note.slug), {
      href: `/notes/${note.slug}/`,
      kind: "笔记",
      title: note.data.title ?? "未命名笔记"
    });
  }

  return references.map((entry) => {
    const relatedReferenceSlugs = buildRelatedReferenceSlugs(entry, references);

    return {
      params: { slug: entry.slug },
      props: {
        entry,
        networkLinks: {
          relatedReferences: relatedReferenceSlugs
            .map((slug) => publicReferenceLookup.get(slug))
            .filter(isLinkItem),
          relatedScripts: (entry.data.relatedScripts ?? [])
            .map((slug) => publicArticleLookup.get(slug))
            .filter(isLinkItem)
        },
        backlinks: (graph.backlinks[makeEntryId("references", entry.slug)] ?? []).map((entryId) => {
          const match = sourceLookup.get(entryId);

          return (
            match ?? {
              href: "#",
              kind: "内容",
              title: entryId
            }
          );
        })
      }
    };
  });
}

const { entry, backlinks, networkLinks } = Astro.props;
const readingState = buildReferenceReadingState(entry.data);
const referenceIntro = buildReferenceIntro(entry.data);
---

<PostLayout title={entry.data.title} summary={entry.data.summary} date={entry.data.date}>
  <section class="reading-section stack">
    <div class="reading-section__header">
      <h2>这份资料在讲什么</h2>
    </div>
    <div class="reading-block">
      <p>{referenceIntro}</p>
    </div>
  </section>

  <Fragment slot="lead">
    <ReferenceMeta entry={entry} />
    <section class="glass-panel side-panel stack">
      <h2>关联内容</h2>
      <p class="muted">
        这里收纳这份资料在站内的别名、主题归属、直接关联条目，以及之后会继续扩展的互链关系。
      </p>

      {(entry.data.aliases?.length ?? 0) > 0 && (
        <div class="stack">
          <strong class="panel-label">别名</strong>
          <ul class="inline-list">
            {entry.data.aliases?.map((alias) => <li><span>{alias}</span></li>)}
          </ul>
        </div>
      )}

      {(entry.data.topics?.length ?? 0) > 0 && (
        <div class="stack">
          <strong class="panel-label">主题</strong>
          <ul class="inline-list">
            {entry.data.topics?.map((topic) => (
              <li><a href={`/topics/${topic}/`}>{topic}</a></li>
            ))}
          </ul>
        </div>
      )}

      {networkLinks.relatedReferences.length > 0 && (
        <div class="stack">
          <strong class="panel-label">关联参考资料</strong>
          <ul class="network-list">
            {networkLinks.relatedReferences.map((item) => (
              <li><a href={item.href}>{item.title}</a></li>
            ))}
          </ul>
        </div>
      )}

      {networkLinks.relatedScripts.length > 0 && (
        <div class="stack">
          <strong class="panel-label">关联视频稿</strong>
          <ul class="network-list">
            {networkLinks.relatedScripts.map((item) => (
              <li><a href={item.href}>{item.title}</a></li>
            ))}
          </ul>
        </div>
      )}

      {networkLinks.relatedReferences.length === 0 &&
        networkLinks.relatedScripts.length === 0 &&
        (entry.data.aliases?.length ?? 0) === 0 &&
        (entry.data.topics?.length ?? 0) === 0 && (
          <p class="muted">这份资料已经准备好继续接入更多站内链接，后续补充主稿、笔记和相关节点时会逐步长出关系网。</p>
        )}
    </section>
  </Fragment>
  <ReferenceReading blocks={readingState.blocks} extract={readingState.extract} />
  <BacklinkList slot="after" items={backlinks} />
</PostLayout>
