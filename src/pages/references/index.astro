---
import ArchiveOverview from "../../components/ArchiveOverview.astro";
import { getReferenceOverviewCovers } from "../../lib/archive-covers";
import { loadReferencesConfig } from "../../lib/home-config";
import { partitionReferenceLibrary } from "../../lib/reference-library";
import { getPublishedReferences } from "../../lib/public-content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const config = await loadReferencesConfig();
const references = await getPublishedReferences();
const { topicEntries, sourceGroups } = partitionReferenceLibrary(references);
const sourceEntries = sourceGroups.flatMap((group) => group.entries);
const items = [...topicEntries, ...sourceEntries].map((entry) => ({
  category: entry.data.librarySection,
  covers: getReferenceOverviewCovers(entry.data),
  date: entry.data.date,
  eyebrow: entry.data.kind === "source" ? entry.data.librarySection ?? "来源资料" : "专题资料",
  href: `/references/${entry.slug}/`,
  meta: entry.data.sourceTitle ?? "查看资料",
  summary: entry.data.summary,
  tags: entry.data.tags ?? [],
  title: entry.data.title,
}));
---

<BaseLayout title={config.title} description={config.description}>
  <ArchiveOverview
    archiveStyle="reference"
    description={config.description}
    eyebrow="Archive & Search"
    items={items}
    searchPlaceholder="搜索资料、来源、专题..."
    title={config.title}
    totalLabel="总计"
  />
</BaseLayout>
