---
import ArticleCard from "../components/ArticleCard.astro";
import ReferenceCard from "../components/ReferenceCard.astro";
import { loadHomeConfig } from "../lib/home-config";
import { getPublishedArticles, getPublishedReferences } from "../lib/public-content";
import BaseLayout from "../layouts/BaseLayout.astro";

const config = await loadHomeConfig();
const articles = await getPublishedArticles();
const references = await getPublishedReferences();
---

<BaseLayout>
  {
    config.blocks.map((block) => {
      if (block.type === "article-list") {
        const entries = articles
          .filter((entry) => !block.articleType || entry.data.type === block.articleType)
          .slice(0, block.limit);

        return (
          <section class="panel stack">
            <h2>{block.title}</h2>
            <div class="grid cards">
              {entries.map((entry) => <ArticleCard entry={entry} />)}
            </div>
          </section>
        );
      }

      return (
        <section class="panel stack">
          <h2>{block.title}</h2>
          <div class="grid cards">
            {references.slice(0, block.limit).map((entry) => <ReferenceCard entry={entry} />)}
          </div>
        </section>
      );
    })
  }
</BaseLayout>
