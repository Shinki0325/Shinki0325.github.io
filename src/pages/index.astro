---
import HomeSearchBar from "../components/chrome/HomeSearchBar";
import CharacterBirthdayCalendar from "../components/birthdays/CharacterBirthdayCalendar";
import HomeLyricBar from "../components/music/HomeLyricBar";
import HomeMusicCard from "../components/music/HomeMusicCard";
import { siteAppearance, type SiteAppearancePreviewCard } from "../config/site-appearance";
import { siteShell } from "../config/site-shell";
import { birthdayWorks, characterBirthdays } from "../data/character-birthdays";
import { galgameHistoryPreview } from "../data/galgame-history-preview";
import { getArticleOverviewCovers } from "../lib/archive-covers";
import { buildHomeSearchIndex } from "../lib/home-shell";
import {
  getPublishedAlbums,
  getPublishedArticles,
  getPublishedNotes,
  getPublishedReferences,
} from "../lib/public-content";
import BaseLayout from "../layouts/BaseLayout.astro";

const [articles, albums, notes, references] = await Promise.all([
  getPublishedArticles(),
  getPublishedAlbums(),
  getPublishedNotes(),
  getPublishedReferences(),
]);

const formatDate = (value: Date | number | string | undefined) => {
  if (!value) {
    return "持续整理中";
  }

  return new Intl.DateTimeFormat("zh-CN", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(new Date(value));
};

const latestScript = articles.find((entry) => entry.data.type === "script") ?? articles[0] ?? null;
const scriptCarouselEntries = articles.length > 0 ? articles : latestScript ? [latestScript] : [];
const scriptCoverPool = Array.from(
  new Set(scriptCarouselEntries.flatMap((entry) => getArticleOverviewCovers(entry.data)).filter(Boolean)),
);
const scriptSlideCount = Math.max(scriptCarouselEntries.length, scriptCoverPool.length, latestScript ? 1 : 0);
const scriptCarouselSlides = Array.from({ length: scriptSlideCount }, (_, index) => {
  const entry = scriptCarouselEntries[index % Math.max(scriptCarouselEntries.length, 1)] ?? latestScript;

  return {
    cover: scriptCoverPool[index % Math.max(scriptCoverPool.length, 1)] ?? "",
    date: formatDate(entry?.data.date),
    eyebrow: entry?.data.type === "script" ? "LATEST INSIGHT" : "LATEST ARTICLE",
    href: entry ? `/articles/${entry.slug}/` : "/articles/",
    label: entry?.data.type === "script" ? "文稿" : "文章",
    summary: entry?.data.summary ?? "主文稿会把资料库、笔记和时间线线索收拢成一条更适合公开阅读的叙述。",
    title: entry?.data.title ?? "文稿整理中",
  };
});
const firstScriptSlide = scriptCarouselSlides[0];
const featuredReference = references[0] ?? null;
const latestNote = notes[0] ?? null;
const searchItems = buildHomeSearchIndex({ articles, albums, notes, references });
const githubHref = siteShell.social?.github ?? "";
const bilibiliHref = siteShell.social?.bilibili ?? "";
const normalizeSocialHref = (value: string | undefined, kind: "email" | "url") => {
  if (!value) {
    return "";
  }

  if (kind === "email" && !value.startsWith("mailto:")) {
    return `mailto:${value}`;
  }

  return value;
};
const emailHref = normalizeSocialHref(siteShell.social?.email, "email");

const latestUpdate = formatDate(
  [...articles, ...albums, ...notes, ...references]
    .map((entry) => new Date(entry.data.date).getTime())
    .filter((value) => Number.isFinite(value))
    .sort((left, right) => right - left)[0],
);

const noteSummary = latestNote?.data.tags?.length
  ? `围绕 ${latestNote.data.tags.slice(0, 2).join(" / ")} 的整理笔记`
  : "把零散线索先整理成可继续扩写的工作台。";

type HomeCardId = "featured" | "reference" | "notes" | "status";

const homeCardFallbacks: Record<HomeCardId, SiteAppearancePreviewCard> = {
  featured: {
    id: "featured",
    eyebrow: "当前主稿",
    title: "当前主稿",
    description: "",
    meta: "文稿",
    actionLabel: "打开文稿",
    variant: "strong",
    widthUnits: 5,
    minHeight: 260,
  },
  reference: {
    id: "reference",
    eyebrow: "重点资料",
    title: "重点资料",
    description: "",
    meta: "资料库",
    actionLabel: "打开资料页",
    variant: "strong",
    widthUnits: 7,
    minHeight: 260,
  },
  notes: {
    id: "notes",
    eyebrow: "最新笔记",
    title: "最新笔记",
    description: "",
    meta: "笔记",
    actionLabel: "打开笔记",
    variant: "soft",
    widthUnits: 4,
    minHeight: 180,
  },
  status: {
    id: "status",
    eyebrow: "运行回廊",
    title: "运行回廊",
    description: "",
    meta: "Live",
    actionLabel: "查看状态",
    variant: "outline",
    widthUnits: 4,
    minHeight: 180,
  },
};

const homeCardConfig = new Map(siteAppearance.previewCards.map((card) => [card.id, card]));
const getHomeCard = (id: HomeCardId) => homeCardConfig.get(id) ?? homeCardFallbacks[id];
const getHomeFeatureCardClass = (id: HomeCardId, extraClass = "") => {
  const card = getHomeCard(id);

  return ["home-feature-card", `home-feature-card--variant-${card.variant}`, extraClass, "glass-card", "interactive-lift"]
    .filter(Boolean)
    .join(" ");
};
const getHomeFeatureCardStyle = (id: HomeCardId) => {
  const card = getHomeCard(id);

  return `--home-feature-card-span: ${card.widthUnits}; --home-feature-card-min-height: ${card.minHeight}px;`;
};
const chronicleRoute = galgameHistoryPreview.museumRoute;
const chronicleSummary = {
  startYear: chronicleRoute.timeDomain.startYear,
  endYear: chronicleRoute.timeDomain.endYear,
  publicDossierCount: chronicleRoute.authority.publicDossierCount,
  storyCount: chronicleRoute.authority.storyCount,
  branchCount: chronicleRoute.authority.branchCount,
  eras: chronicleRoute.galleries.map((gallery) => ({
    id: gallery.id,
    label: gallery.theme,
    startYear: gallery.yearStart,
    endYear: gallery.yearEnd,
  })),
};
const chronicleMiniTracks = [
  { id: "works", nodes: 7 },
  { id: "public", nodes: 6 },
  { id: "systems", nodes: 7 },
] as const;
---

<BaseLayout>
  <HomeSearchBar client:load items={searchItems} placeholder={siteShell.search?.placeholder ?? "搜索站内内容..."} />

  <section class="home-hero-shell" data-home-hero>
    <div class="home-hero-grid">
      <article class="home-profile-card glass-card" data-home-profile-card>
        <div class="home-profile-card__top">
          <div class="home-profile-avatar-shell">
            <div class="home-profile-avatar-frame">
              <img
                alt={`${siteShell.profile?.displayName ?? siteShell.brand.title} 头像`}
                class="home-profile-avatar"
                src={siteShell.profile?.avatarUrl ?? "https://s1.ax1x.com/2023/07/28/pCx6j3R.jpg"}
              />
            </div>
          </div>

          <div class="home-profile-copy">
            <p class="eyebrow">{siteShell.hero.eyebrow}</p>
            <h1>{siteShell.profile?.displayName ?? siteShell.brand.title}</h1>
            {(siteShell.profile?.bio ?? siteShell.hero.description) ? (
              <p class="home-profile-bio">{siteShell.profile?.bio ?? siteShell.hero.description}</p>
            ) : null}
            {siteShell.hero.title ? <p class="home-profile-note">{siteShell.hero.title}</p> : null}
          </div>
        </div>

        <div class="home-profile-footer">
          <div class="home-stat-grid">
            <article class="home-stat-card">
              <strong>{articles.length}</strong>
              <span>文稿</span>
            </article>
            <article class="home-stat-card">
              <strong>{references.length}</strong>
              <span>条目</span>
            </article>
          </div>

          <div class="home-social-row">
            {githubHref ? (
              <a class="home-social-button interactive-lift" href={githubHref} rel="noreferrer" target="_blank" title="GitHub">
                <svg fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.49.5.09.68-.22.68-.48 0-.24-.01-.87-.01-1.7-2.78.6-3.37-1.34-3.37-1.34-.46-1.16-1.11-1.46-1.11-1.46-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.03A9.6 9.6 0 0 1 12 6.84c.85 0 1.7.12 2.5.34 1.91-1.3 2.75-1.03 2.75-1.03.54 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.93.36.31.68.92.68 1.85 0 1.34-.01 2.42-.01 2.75 0 .26.18.58.69.48A10 10 0 0 0 22 12c0-5.52-4.48-10-10-10Z" />
                </svg>
              </a>
            ) : null}
            {bilibiliHref ? (
              <a class="home-social-button interactive-lift" href={bilibiliHref} rel="noreferrer" target="_blank" title="Bilibili">
                <svg fill="none" viewBox="0 0 24 24">
                  <path d="M7 5.5 9.2 8M17 5.5 14.8 8" />
                  <path d="M6.5 8.5h11a2.5 2.5 0 0 1 2.5 2.5v5A2.5 2.5 0 0 1 17.5 18.5h-11A2.5 2.5 0 0 1 4 16v-5a2.5 2.5 0 0 1 2.5-2.5Z" />
                  <path d="M9.5 12v.2M14.5 12v.2M9 15.2c1.8.7 4.2.7 6 0" />
                </svg>
              </a>
            ) : (
              <button class="home-social-button is-disabled" disabled title="Bilibili">
                <svg fill="none" viewBox="0 0 24 24">
                  <path d="M7 5.5 9.2 8M17 5.5 14.8 8" />
                  <path d="M6.5 8.5h11a2.5 2.5 0 0 1 2.5 2.5v5A2.5 2.5 0 0 1 17.5 18.5h-11A2.5 2.5 0 0 1 4 16v-5a2.5 2.5 0 0 1 2.5-2.5Z" />
                  <path d="M9.5 12v.2M14.5 12v.2M9 15.2c1.8.7 4.2.7 6 0" />
                </svg>
              </button>
            )}
            {emailHref ? (
              <a class="home-social-button interactive-lift" href={emailHref} title="邮箱">
                <svg fill="none" viewBox="0 0 24 24">
                  <path d="M4 7.5h16v9H4z" />
                  <path d="m4.5 8 7.5 6 7.5-6" />
                </svg>
              </a>
            ) : null}
          </div>
        </div>
      </article>

      <div class="home-sidebar-stack">
        <HomeMusicCard client:load />
      </div>
    </div>
  </section>

  <HomeLyricBar client:load />

  <section class="home-feature-grid" data-home-feature-grid>
    <a
      aria-label="进入 Galgame Chronicle 美少女游戏编年档案"
      class="home-history-entry glass-card"
      data-home-history-entry
      data-home-chronicle-slot="01"
      href="/galgame-history/"
    >
      <span class="home-history-entry__registration">
        <strong>01</strong>
        <span>ARCHIVE DATA</span>
        <em>ONLINE</em>
      </span>

      <span class="home-history-entry__content">
        <span class="home-history-entry__identity">
          <span>
            <strong>GALGAME CHRONICLE</strong>
            <b>美少女游戏编年档案</b>
          </span>
          <time>{chronicleSummary.startYear}-{chronicleSummary.endYear}</time>
        </span>

        <span class="home-history-entry__counts" aria-label="公开档案概况">
          <b>{chronicleSummary.publicDossierCount} <small>FILES</small></b>
          <b>{chronicleSummary.storyCount} <small>STORY</small></b>
          <b>{chronicleSummary.branchCount} <small>BRANCH</small></b>
        </span>

        <span class="home-history-entry__record">
          <span class="home-history-entry__mini-map" aria-hidden="true">
            {chronicleMiniTracks.map((track, trackIndex) => (
              <i
                class={`home-history-entry__mini-track home-history-entry__mini-track--${track.id}`}
                style={`--track-index: ${trackIndex}`}
              >
                {Array.from({ length: track.nodes }, (_, nodeIndex) => (
                  <i style={`--node-index: ${nodeIndex}; --node-progress: ${nodeIndex / Math.max(track.nodes - 1, 1)}`}></i>
                ))}
              </i>
            ))}
          </span>

          <span class="home-history-entry__eras">
            {chronicleSummary.eras.map((era, index) => (
              <span style={`--era-index: ${index}`}>
                <b>{era.label}</b>
                <small>{era.startYear}-{era.endYear}</small>
              </span>
            ))}
          </span>
        </span>
      </span>

      <span class="home-history-entry__load">
        <i aria-hidden="true"></i>
        <strong>LOAD ARCHIVE</strong>
        <span aria-hidden="true"></span>
      </span>
    </a>

    <div class="home-feature-card--calendar" data-home-birthday-calendar>
      <CharacterBirthdayCalendar
        characters={characterBirthdays}
        client:only="react"
        works={birthdayWorks}
      />
    </div>

    <a
      class={getHomeFeatureCardClass("featured", "home-feature-card--primary home-script-carousel")}
      data-home-script-carousel
      data-home-script-slides={JSON.stringify(scriptCarouselSlides)}
      href={firstScriptSlide?.href ?? "/articles/"}
      style={getHomeFeatureCardStyle("featured")}
    >
      <div class="home-script-carousel__media" aria-hidden="true">
        {firstScriptSlide?.cover ? <img alt="" data-home-script-cover loading="lazy" src={firstScriptSlide.cover} /> : null}
      </div>
      <div class="home-script-carousel__shade" aria-hidden="true"></div>
      <div class="home-script-carousel__content">
        <div class="home-script-carousel__chips">
          <span data-home-script-eyebrow>{firstScriptSlide?.eyebrow ?? "LATEST INSIGHT"}</span>
          <time data-home-script-date>{firstScriptSlide?.date ?? "持续整理中"}</time>
        </div>
        <h2 data-home-script-title>{firstScriptSlide?.title ?? "文稿整理中"}</h2>
        <p data-home-script-summary>{firstScriptSlide?.summary}</p>
        <div class="home-script-carousel__footer">
          <span class="spotlight-label" data-home-script-label>{firstScriptSlide?.label ?? "文稿"}</span>
          <span class="home-script-carousel__dots" aria-label="文稿轮播页码">
            {scriptCarouselSlides.slice(0, 6).map((_, index) => (
              <i class={index === 0 ? "is-active" : ""} data-home-script-dot={index} aria-hidden="true"></i>
            ))}
          </span>
        </div>
      </div>
    </a>

    <a
      class={getHomeFeatureCardClass("reference", "home-feature-card--wide")}
      href={featuredReference ? `/references/${featuredReference.slug}/` : "/references/"}
      style={getHomeFeatureCardStyle("reference")}
    >
      <div class="home-card-head">
        <div>
          <p class="eyebrow">重点资料</p>
          <h2>{featuredReference?.data.title ?? "资料节点整理中"}</h2>
        </div>
        <span class="spotlight-label">资料库</span>
      </div>
      <p class="muted">
        {featuredReference?.data.summary ??
          "优先把可互链、可引用、可继续扩展的资料页放在这里，逐步长成更像 wiki 的站内网络。"}
      </p>
      <div class="home-feature-meta">
        <span>{featuredReference?.data.sourceTitle ?? "公开资料节点"}</span>
        <span class="section-link home-feature-card__cta">打开资料页</span>
      </div>
    </a>

    <a
      class={getHomeFeatureCardClass("notes")}
      href={latestNote ? `/notes/${latestNote.slug}/` : "/notes/"}
      style={getHomeFeatureCardStyle("notes")}
    >
      <div class="home-card-head">
        <div>
          <p class="eyebrow">最新笔记</p>
          <h2>{latestNote?.data.title ?? "笔记整理中"}</h2>
        </div>
        <span class="spotlight-label">笔记</span>
      </div>
      <p class="muted">{noteSummary}</p>
      <span class="section-link home-feature-card__cta">打开笔记</span>
    </a>

    <article class={getHomeFeatureCardClass("status", "home-feature-card--reference")} data-home-reference-card style={getHomeFeatureCardStyle("status")}>
      <div class="home-card-head">
        <div>
          <p class="eyebrow">运行回廊</p>
          <h2>资料岛仍在缓慢发光</h2>
        </div>
        <span class="spotlight-label">Live</span>
      </div>
      <div class="home-reference-orbit" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <dl class="home-reference-stats">
        <div>
          <dt>公开内容</dt>
          <dd>{articles.length + references.length + notes.length + albums.length}</dd>
        </div>
        <div>
          <dt>最新更新</dt>
          <dd>{latestUpdate}</dd>
        </div>
      </dl>
      <p class="muted">文稿、资料库、笔记和照片墙会继续向同一个归档系统汇流。</p>
    </article>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    const parseSlides = (value) => {
      try {
        const parsed = JSON.parse(value || "[]");
        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    };

    const applySlide = (card, slides, index) => {
      const slide = slides[index % slides.length];
      if (!slide) {
        return;
      }

      const cover = card.querySelector("[data-home-script-cover]");
      const title = card.querySelector("[data-home-script-title]");
      const summary = card.querySelector("[data-home-script-summary]");
      const eyebrow = card.querySelector("[data-home-script-eyebrow]");
      const date = card.querySelector("[data-home-script-date]");
      const label = card.querySelector("[data-home-script-label]");

      card.href = slide.href || "/articles/";
      if (cover && slide.cover && cover.getAttribute("src") !== slide.cover) {
        cover.style.opacity = "0";
        window.setTimeout(() => {
          cover.setAttribute("src", slide.cover);
          cover.style.opacity = "1";
        }, 160);
      }
      if (title) title.textContent = slide.title || "文稿整理中";
      if (summary) summary.textContent = slide.summary || "";
      if (eyebrow) eyebrow.textContent = slide.eyebrow || "LATEST INSIGHT";
      if (date) date.textContent = slide.date || "持续整理中";
      if (label) label.textContent = slide.label || "文稿";

      card.querySelectorAll("[data-home-script-dot]").forEach((dot) => {
        dot.classList.toggle("is-active", Number(dot.dataset.homeScriptDot) === index % Math.min(slides.length, 6));
      });
    };

    const initHomeScriptCarousels = () => {
      document.querySelectorAll("[data-home-script-carousel]").forEach((card) => {
        if (card.dataset.homeScriptCarouselReady) {
          return;
        }
        const slides = parseSlides(card.dataset.homeScriptSlides);
        if (slides.length <= 1) {
          return;
        }

        card.dataset.homeScriptCarouselReady = "true";
        let index = 0;
        window.setInterval(() => {
          index = (index + 1) % slides.length;
          applySlide(card, slides, index);
        }, 6000);
      });
    };

    document.addEventListener("astro:page-load", initHomeScriptCarousels);
    initHomeScriptCarousels();
  })();
</script>
