---
import HomeSearchBar from "../components/chrome/HomeSearchBar";
import HomeLyricBar from "../components/music/HomeLyricBar";
import HomeMusicCard from "../components/music/HomeMusicCard";
import { siteShell } from "../config/site-shell";
import { buildHomeSearchIndex } from "../lib/home-shell";
import {
  getPublishedAlbums,
  getPublishedArticles,
  getPublishedNotes,
  getPublishedReferences,
} from "../lib/public-content";
import BaseLayout from "../layouts/BaseLayout.astro";

const [articles, albums, notes, references] = await Promise.all([
  getPublishedArticles(),
  getPublishedAlbums(),
  getPublishedNotes(),
  getPublishedReferences(),
]);

const latestScript = articles.find((entry) => entry.data.type === "script") ?? articles[0] ?? null;
const featuredReference = references[0] ?? null;
const latestNote = notes[0] ?? null;
const searchItems = buildHomeSearchIndex({ articles, albums, notes, references });
const githubHref = siteShell.social?.github ?? "";
const bilibiliHref = siteShell.social?.bilibili ?? "";
const normalizeSocialHref = (value: string | undefined, kind: "email" | "url") => {
  if (!value) {
    return "";
  }

  if (kind === "email" && !value.startsWith("mailto:")) {
    return `mailto:${value}`;
  }

  return value;
};
const emailHref = normalizeSocialHref(siteShell.social?.email, "email");

const formatDate = (value: Date | string | undefined) => {
  if (!value) {
    return "持续整理中";
  }

  return new Intl.DateTimeFormat("zh-CN", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(new Date(value));
};

const latestUpdate = formatDate(
  [...articles, ...albums, ...notes, ...references]
    .map((entry) => new Date(entry.data.date).getTime())
    .filter((value) => Number.isFinite(value))
    .sort((left, right) => right - left)[0],
);

const noteSummary = latestNote?.data.tags?.length
  ? `围绕 ${latestNote.data.tags.slice(0, 2).join(" / ")} 的整理笔记`
  : "把零散线索先整理成可继续扩写的工作台。";
---

<BaseLayout>
  <HomeSearchBar client:load items={searchItems} placeholder={siteShell.search?.placeholder ?? "搜索站内内容..."} />

  <section class="home-hero-shell" data-home-hero>
    <div class="home-hero-grid">
      <article class="home-profile-card glass-card" data-home-profile-card>
        <div class="home-profile-card__top">
          <div class="home-profile-avatar-shell">
            <div class="home-profile-avatar-frame">
              <img
                alt={`${siteShell.profile?.displayName ?? siteShell.brand.title} 头像`}
                class="home-profile-avatar"
                src={siteShell.profile?.avatarUrl ?? "https://s1.ax1x.com/2023/07/28/pCx6j3R.jpg"}
              />
            </div>
          </div>

          <div class="home-profile-copy">
            <p class="eyebrow">{siteShell.hero.eyebrow}</p>
            <h1>{siteShell.profile?.displayName ?? siteShell.brand.title}</h1>
            {(siteShell.profile?.bio ?? siteShell.hero.description) ? (
              <p class="home-profile-bio">{siteShell.profile?.bio ?? siteShell.hero.description}</p>
            ) : null}
            {siteShell.hero.title ? <p class="home-profile-note">{siteShell.hero.title}</p> : null}
          </div>
        </div>

        <div class="home-profile-footer">
          <div class="home-stat-grid">
            <article class="home-stat-card">
              <strong>{articles.length}</strong>
              <span>文稿</span>
            </article>
            <article class="home-stat-card">
              <strong>{references.length}</strong>
              <span>条目</span>
            </article>
          </div>

          <div class="home-social-row">
            {githubHref ? (
              <a class="home-social-button" href={githubHref} rel="noreferrer" target="_blank" title="GitHub">
                <svg fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.49.5.09.68-.22.68-.48 0-.24-.01-.87-.01-1.7-2.78.6-3.37-1.34-3.37-1.34-.46-1.16-1.11-1.46-1.11-1.46-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.03A9.6 9.6 0 0 1 12 6.84c.85 0 1.7.12 2.5.34 1.91-1.3 2.75-1.03 2.75-1.03.54 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.93.36.31.68.92.68 1.85 0 1.34-.01 2.42-.01 2.75 0 .26.18.58.69.48A10 10 0 0 0 22 12c0-5.52-4.48-10-10-10Z" />
                </svg>
              </a>
            ) : null}
            {bilibiliHref ? (
              <a class="home-social-button" href={bilibiliHref} rel="noreferrer" target="_blank" title="Bilibili">
                <svg fill="none" viewBox="0 0 24 24">
                  <path d="M7 5.5 9.2 8M17 5.5 14.8 8" />
                  <path d="M6.5 8.5h11a2.5 2.5 0 0 1 2.5 2.5v5A2.5 2.5 0 0 1 17.5 18.5h-11A2.5 2.5 0 0 1 4 16v-5a2.5 2.5 0 0 1 2.5-2.5Z" />
                  <path d="M9.5 12v.2M14.5 12v.2M9 15.2c1.8.7 4.2.7 6 0" />
                </svg>
              </a>
            ) : (
              <button class="home-social-button is-disabled" disabled title="Bilibili">
                <svg fill="none" viewBox="0 0 24 24">
                  <path d="M7 5.5 9.2 8M17 5.5 14.8 8" />
                  <path d="M6.5 8.5h11a2.5 2.5 0 0 1 2.5 2.5v5A2.5 2.5 0 0 1 17.5 18.5h-11A2.5 2.5 0 0 1 4 16v-5a2.5 2.5 0 0 1 2.5-2.5Z" />
                  <path d="M9.5 12v.2M14.5 12v.2M9 15.2c1.8.7 4.2.7 6 0" />
                </svg>
              </button>
            )}
            {emailHref ? (
              <a class="home-social-button" href={emailHref} title="邮箱">
                <svg fill="none" viewBox="0 0 24 24">
                  <path d="M4 7.5h16v9H4z" />
                  <path d="m4.5 8 7.5 6 7.5-6" />
                </svg>
              </a>
            ) : null}
          </div>
        </div>
      </article>

      <div class="home-sidebar-stack">
        <HomeMusicCard client:load />
      </div>
    </div>
  </section>

  <HomeLyricBar client:load />

  <section class="home-feature-grid" data-home-feature-grid>
    <article class="home-feature-card home-feature-card--primary glass-card">
      <div class="home-card-head">
        <div>
          <p class="eyebrow">当前主稿</p>
          <h2>{latestScript?.data.title ?? "文稿整理中"}</h2>
        </div>
        <span class="spotlight-label">{latestScript?.data.type === "script" ? "文稿" : "文章"}</span>
      </div>
      <p class="muted">
        {latestScript?.data.summary ?? "主文稿会把资料库、笔记和时间线线索收拢成一条更适合公开阅读的叙述。"}
      </p>
      {latestScript && (
        <a class="section-link" href={`/articles/${latestScript.slug}/`}>
          打开文稿
        </a>
      )}
    </article>

    <article class="home-feature-card home-feature-card--wide glass-card">
      <div class="home-card-head">
        <div>
          <p class="eyebrow">重点资料</p>
          <h2>{featuredReference?.data.title ?? "资料节点整理中"}</h2>
        </div>
        <span class="spotlight-label">资料库</span>
      </div>
      <p class="muted">
        {featuredReference?.data.summary ??
          "优先把可互链、可引用、可继续扩展的资料页放在这里，逐步长成更像 wiki 的站内网络。"}
      </p>
      <div class="home-feature-meta">
        <span>{featuredReference?.data.sourceTitle ?? "公开资料节点"}</span>
        <a class="section-link" href={featuredReference ? `/references/${featuredReference.slug}/` : "/references/"}>
          打开资料页
        </a>
      </div>
    </article>

    <article class="home-feature-card glass-card">
      <div class="home-card-head">
        <div>
          <p class="eyebrow">最新笔记</p>
          <h2>{latestNote?.data.title ?? "笔记整理中"}</h2>
        </div>
        <span class="spotlight-label">笔记</span>
      </div>
      <p class="muted">{noteSummary}</p>
      <a class="section-link" href={latestNote ? `/notes/${latestNote.slug}/` : "/notes/"}>
        打开笔记
      </a>
    </article>

    <article class="home-feature-card home-feature-card--reference glass-card" data-home-reference-card>
      <div class="home-card-head">
        <div>
          <p class="eyebrow">运行回廊</p>
          <h2>资料岛仍在缓慢发光</h2>
        </div>
        <span class="spotlight-label">Live</span>
      </div>
      <div class="home-reference-orbit" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <dl class="home-reference-stats">
        <div>
          <dt>公开内容</dt>
          <dd>{articles.length + references.length + notes.length + albums.length}</dd>
        </div>
        <div>
          <dt>最新更新</dt>
          <dd>{latestUpdate}</dd>
        </div>
      </dl>
      <p class="muted">文稿、资料库、笔记和照片墙会继续向同一个归档系统汇流。</p>
    </article>
  </section>
</BaseLayout>
