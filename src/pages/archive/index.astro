---
import { getPublishedArticles, getPublishedNotes } from "../../lib/public-content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const articleItems = (await getPublishedArticles()).map((entry) => ({
  type: "视频稿",
  title: entry.data.title,
  slug: `/articles/${entry.slug}/`,
  date: entry.data.date
}));

const noteItems = (await getPublishedNotes()).map((entry) => ({
  type: "笔记",
  title: entry.data.title ?? "未命名笔记",
  slug: `/notes/${entry.slug}/`,
  date: entry.data.date
}));

const items = [...articleItems, ...noteItems].sort(
  (a, b) => b.date.getTime() - a.date.getTime()
);
---

<BaseLayout title="归档" description="按时间浏览公开的视频稿与笔记。">
  <section class="feature-section glass-panel stack">
    <div class="section-head">
      <div>
        <p class="eyebrow">时间归档</p>
        <h2>归档</h2>
      </div>
    </div>
    <ul>
      {items.map((item) => (
        <li>
          <span class="muted">{item.date.toISOString().slice(0, 10)} · {item.type}</span>
          {" "}
          <a href={item.slug}>{item.title}</a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
