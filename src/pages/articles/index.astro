---
import ArticleCard from "../../components/ArticleCard.astro";
import { getPublishedArticles } from "../../lib/public-content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const articles = await getPublishedArticles();
---

<BaseLayout title="视频稿" description="公开的视频稿与长文条目。">
  <section class="feature-section glass-panel stack">
    <div class="section-head">
      <div>
        <p class="eyebrow">视频稿栏目</p>
        <h2>视频稿</h2>
      </div>
    </div>
    <div class="grid cards">
      {articles.map((entry) => <ArticleCard entry={entry} />)}
    </div>
  </section>
</BaseLayout>
