# Optional S3-compatible image host for original album/background images.
# Local WebP previews are still generated under /public/uploads.
IMAGE_HOST_PROVIDER=s3
IMAGE_HOST_ENDPOINT=https://example.r2.cloudflarestorage.com
IMAGE_HOST_BUCKET=your-bucket
IMAGE_HOST_REGION=auto
IMAGE_HOST_ACCESS_KEY_ID=your-access-key
IMAGE_HOST_SECRET_ACCESS_KEY=your-secret-key
IMAGE_HOST_PUBLIC_BASE_URL=https://img.example.com
