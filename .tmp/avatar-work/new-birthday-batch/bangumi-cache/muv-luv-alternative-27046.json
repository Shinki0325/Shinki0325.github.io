動や行動を目撃されており、他のメンバーから密かに暴走の危険がないかと心配されている。","name":"ラキュース・アルベイン・デイル・アインドラ","infobox":[{"key":"简体中文名","value":"菈秋丝·阿尔贝茵·提尔·安多菈"},{"key":"别名","value":[{"k":"英文名","v":"lakyus alvein dale aindra"}]},{"key":"性别","value":"女"}],"stat":{"comments":3,"collects":14},"id":34853,"locked":false,"type":1,"nsfw":false},{"birth_mon":4,"gender":"female","birth_day":15,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/00/43/70395_crt_AOYAn.jpg?r=1584947177","grid":"https://lain.bgm.tv/pic/crt/g/00/43/70395_crt_AOYAn.jpg?r=1584947177","large":"https://lain.bgm.tv/pic/crt/l/00/43/70395_crt_AOYAn.jpg?r=1584947177","medium":"https://lain.bgm.tv/r/400/pic/crt/l/00/43/70395_crt_AOYAn.jpg?r=1584947177"},"summary":"维多利亚格拉斯哥帮武斗派头目。推进之王的下属之一。在罗德岛担任推进之王的直属护卫，偶尔会被邀请参与一些实战指导的工作（其实就是实战训练的对手）。","name":"因陀罗","infobox":[{"key":"简体中文名","value":"因陀罗"},{"key":"别名","value":[{"k":"本名","v":"汉娜·“因陀罗”·杰克森"},{"k":"英文名","v":"Indra"},{"k":"日文名","v":"インドラ"}]},{"key":"性别","value":"女"},{"key":"生日","value":"4月15日"},{"key":"身高","value":"173cm"},{"key":"战斗经验","value":"五年"},{"key":"种族","value":"菲林"},{"key":"矿石病感染情况","value":"体表未发现任何源石结晶，确认为非感染者。"}],"stat":{"comments":8,"collects":5},"id":70395,"locked":false,"type":1,"nsfw":false},{"birth_mon":null,"gender":"female","birth_day":null,"birth_year":null,"blood_type":null,"images":{"small":"https://lain.bgm.tv/r/100/pic/crt/l/e2/17/57457_crt_dpLE8.jpg?r=1504234573","grid":"https://lain.bgm.tv/pic/crt/g/e2/17/57457_crt_dpLE8.jpg?r=1504234573","large":"https://lain.bgm.tv/pic/crt/l/e2/17/57457_crt_dpLE8.jpg?r=1504234573","medium":"https://lain.bgm.tv/r/400/pic/crt/l/e2/17/57457_crt_dpLE8.jpg?r=1504234573"},"summary":"マルティナの娘。勝気な性格。従妹のエレオノーラの数少ない同年代の友人として、彼女から色々な相談を受ける立場にある。\r\n    女王になったエレオノーラが幻晶騎士を操縦出来ないため、複座仕様で再建された国王騎カルトガ・オル・クシェール二世の騎操士を務める。","name":"イサドラ・アダリナ・クシェペルカ","infobox":[{"key":"别名","value":[]},{"key":"性别","value":"女"}],"stat":{"comments":0,"collects":4},"id":57457,"locked":false,"type":1,"nsfw":false}],"total":7,"limit":1